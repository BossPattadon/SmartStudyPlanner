// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id  String  @id @default(cuid())
  email String  @unique
  password  String
  name  String
  timezone  String  @default("Asia/Bangkok")
  dailyTargetHours  Float @default(2)
  createdAt  DateTime  @default(now())

  subjects  Subject[]
  tasks Task[]
  studyBlocks  StudyBlock[]
  studySessions StudySession[]
}

model Subject {
  id  String  @id @default(cuid())
  userId  String
  name  String
  color String  @default("#3b82f6")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@index([userId])
}

model Task {
  id  String  @id @default(cuid())
  userId  String
  subjectId String?
  title String
  description String?
  type  String  // 'assignment' | 'exam' | 'reading'
  dueDate DateTime
  estimatedHours Float
  priority  Int @default(3) // 1-5
  difficulty  Int @default(3) // 1-5
  status  String  @default("todo") // 'todo' | 'in_progress' | 'done'
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject Subject?  @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  blocks  StudyBlock[]
  sessions  StudySession[]

  @@index([userId, status])
  @@index([dueDate])
}

model StudyBlock {
  id  String  @id @default(cuid())
  userId  String
  taskId  String
  scheduledStart DateTime
  scheduledEnd DateTime
  status  String  @default("planned")  // 'planned' | 'done' | 'skipped'
  generatedBy String  @default("ai")  // 'ai' | 'manual'

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  task  Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  sessions  StudySession[]

  @@index([userId, scheduledStart])
}

model StudySession {
  id  String  @id @default(cuid())
  userId  String
  taskId  String
  blockId String?
  startedAt DateTime
  endedAt DateTime?
  pomodorosCompleted  Int @default(0)
  notes String?

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  task  Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  block StudyBlock? @relation(fields: [blockId], references: [id], onDelete: SetNull)

  @@index([userId, startedAt])
}



